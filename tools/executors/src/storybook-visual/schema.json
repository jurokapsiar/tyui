{
  "$schema": "http://json-schema.org/schema",
  "type": "object",
  "properties": {
    "port": {
      "type": "number",
      "default": 6010
    },
    "themes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": ["light", "dark"]
    },
    "viewports": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["narrow", "mobile", "tablet", "desktop"]
      },
      "default": ["narrow", "mobile", "tablet", "desktop"]
    },
    "updateSnapshots": {
      "type": "boolean",
      "default": false
    }
  }
}
