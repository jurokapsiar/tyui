{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2023",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": [],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "paths": {
      "@tyui/core": ["./libs/core/src/index.ts"],
      "@tyui/elements": ["./libs/elements/src/index.ts"],
      "@tyui/elements/button": ["./libs/elements/src/button/index.ts"],
      "@tyui/elements/center": ["./libs/elements/src/center/index.ts"],
      "@tyui/elements/checkbox": ["./libs/elements/src/checkbox/index.ts"],
      "@tyui/elements/cluster": ["./libs/elements/src/cluster/index.ts"],
      "@tyui/elements/container": ["./libs/elements/src/container/index.ts"],
      "@tyui/elements/flex": ["./libs/elements/src/flex/index.ts"],
      "@tyui/elements/frame": ["./libs/elements/src/frame/index.ts"],
      "@tyui/elements/grid": ["./libs/elements/src/grid/index.ts"],
      "@tyui/elements/input": ["./libs/elements/src/input/index.ts"],
      "@tyui/elements/radio": ["./libs/elements/src/radio/index.ts"],
      "@tyui/elements/radio-group": ["./libs/elements/src/radio-group/index.ts"],
      "@tyui/elements/sidebar": ["./libs/elements/src/sidebar/index.ts"],
      "@tyui/define": ["./libs/define/src/index.ts"],
      "@tyui/define/button": ["./libs/define/src/button.ts"],
      "@tyui/define/center": ["./libs/define/src/center.ts"],
      "@tyui/define/checkbox": ["./libs/define/src/checkbox.ts"],
      "@tyui/define/cluster": ["./libs/define/src/cluster.ts"],
      "@tyui/define/container": ["./libs/define/src/container.ts"],
      "@tyui/define/flex": ["./libs/define/src/flex.ts"],
      "@tyui/define/frame": ["./libs/define/src/frame.ts"],
      "@tyui/define/grid": ["./libs/define/src/grid.ts"],
      "@tyui/define/input": ["./libs/define/src/input.ts"],
      "@tyui/define/radio": ["./libs/define/src/radio.ts"],
      "@tyui/define/radio-group": ["./libs/define/src/radio-group.ts"],
      "@tyui/define/sidebar": ["./libs/define/src/sidebar.ts"],
      "@tyui/define/all": ["./libs/define/src/all.ts"],
      "@tyui/solid": ["./libs/solid/src/index.ts"],
      "@tyui/solid/button": ["./libs/solid/src/button.tsx"],
      "@tyui/solid/jsx": ["./libs/solid/src/jsx.ts"],
      "@tyui/testing": ["./libs/testing/src/index.ts"],
      "@tyui/tools-executors": ["./tools/executors/src/index.ts"],
      "@tyui/tools-executors/*": ["./tools/executors/src/*"],
      "@tyui/tools-workspace": ["./tools/workspace/src/index.ts"]
    }
  }
}
