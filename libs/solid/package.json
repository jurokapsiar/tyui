    "./define/sidebar": {
      "types": "./dist/define/sidebar.d.ts",
      "default": "./dist/define/sidebar.js"
    },
    "./custom-elements.json": {
      "default": "./custom-elements.json"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit"
