    "./define/grid": {
      "types": "./dist/define/grid.d.ts",
      "default": "./dist/define/grid.js"
    },
    "./define/input": {
      "types": "./dist/define/input.d.ts",
      "default": "./dist/define/input.js"
    },
    "./define/radio": {
      "types": "./dist/define/radio.d.ts",
