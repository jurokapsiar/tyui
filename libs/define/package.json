{
  "name": "@tyui/define",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./button": {
      "types": "./src/button.ts",
      "default": "./dist/button.js"
    },
    "./center": {
      "types": "./src/center.ts",
      "default": "./dist/center.js"
    },
    "./checkbox": {
      "types": "./src/checkbox.ts",
      "default": "./dist/checkbox.js"
    },
    "./cluster": {
      "types": "./src/cluster.ts",
      "default": "./dist/cluster.js"
    },
    "./container": {
      "types": "./src/container.ts",
      "default": "./dist/container.js"
    },
    "./flex": {
      "types": "./src/flex.ts",
      "default": "./dist/flex.js"
    },
    "./frame": {
      "types": "./src/frame.ts",
      "default": "./dist/frame.js"
    },
    "./grid": {
      "types": "./src/grid.ts",
      "default": "./dist/grid.js"
    },
    "./input": {
      "types": "./src/input.ts",
      "default": "./dist/input.js"
    },
    "./radio": {
      "types": "./src/radio.ts",
      "default": "./dist/radio.js"
    },
    "./radio-group": {
      "types": "./src/radio-group.ts",
      "default": "./dist/radio-group.js"
    },
    "./sidebar": {
      "types": "./src/sidebar.ts",
      "default": "./dist/sidebar.js"
    },
    "./all": {
      "types": "./src/all.ts",
      "default": "./dist/all.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit"
  },
  "dependencies": {
    "@tyui/elements": "workspace:*"
  },
  "devDependencies": {
    "@tyui/tools-executors": "workspace:*"
  }
}
