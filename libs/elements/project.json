{
  "name": "elements",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/elements/src",
  "implicitDependencies": ["core"],
  "targets": {
    "build": {
      "executor": "@toyu-ui/tools-executors:build",
      "dependsOn": ["cem", "skills:validate", "ai-context"]
    },
    "test": {
      "executor": "@toyu-ui/tools-executors:test",
      "options": {
        "browser": true,
        "watch": false,
        "coverage": false
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "libs/elements",
        "command": "tsc -p tsconfig.lib.json --noEmit"
      }
    },
    "storybook": {
      "executor": "@toyu-ui/tools-executors:storybook",
      "dependsOn": ["storybook-docs"],
      "options": {
        "framework": "web-components",
        "port": 6006,
        "mode": "dev"
      }
    },
    "storybook-docs": {
      "executor": "@toyu-ui/tools-executors:storybook-docs",
      "outputs": ["{projectRoot}/src/generated/spec-docs"]
    },
    "visual": {
      "executor": "@toyu-ui/tools-executors:storybook-visual",
      "dependsOn": ["storybook-docs"],
      "options": {
        "port": 6010,
        "themes": ["light", "dark"],
        "viewports": ["narrow", "mobile", "tablet", "desktop"],
        "updateSnapshots": false
      }
    },
    "e2e": {
      "executor": "@toyu-ui/tools-executors:component-e2e",
      "options": {
        "port": 6011
      }
    },
    "cem": {
      "executor": "@toyu-ui/tools-executors:cem"
    },
    "skills:validate": {
      "executor": "@toyu-ui/tools-executors:skills-validate"
    },
    "ai-context": {
      "executor": "@toyu-ui/tools-executors:ai-context",
      "dependsOn": ["cem", "skills:validate"],
      "options": {
        "includeRootLlms": true
      }
    }
  },
  "tags": ["scope:libs", "type:library"]
}
