{
  "name": "@tyui/elements",
  "version": "0.0.0",
  "private": true,
  "keywords": [
    "tanstack-intent"
  ],
  "files": [
    "dist",
    "skills",
    "!skills/_artifacts",
    "custom-elements.json"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./button": {
      "types": "./src/button/index.ts",
      "default": "./dist/button.js"
    },
    "./center": {
      "types": "./src/center/index.ts",
      "default": "./dist/center.js"
    },
    "./checkbox": {
      "types": "./src/checkbox/index.ts",
      "default": "./dist/checkbox.js"
    },
    "./cluster": {
      "types": "./src/cluster/index.ts",
      "default": "./dist/cluster.js"
    },
    "./container": {
      "types": "./src/container/index.ts",
      "default": "./dist/container.js"
    },
    "./flex": {
      "types": "./src/flex/index.ts",
      "default": "./dist/flex.js"
    },
    "./frame": {
      "types": "./src/frame/index.ts",
      "default": "./dist/frame.js"
    },
    "./grid": {
      "types": "./src/grid/index.ts",
      "default": "./dist/grid.js"
    },
    "./input": {
      "types": "./src/input/index.ts",
      "default": "./dist/input.js"
    },
    "./radio": {
      "types": "./src/radio/index.ts",
      "default": "./dist/radio.js"
    },
    "./radio-group": {
      "types": "./src/radio-group/index.ts",
      "default": "./dist/radio-group.js"
    },
    "./sidebar": {
      "types": "./src/sidebar/index.ts",
      "default": "./dist/sidebar.js"
    },
    "./custom-elements.json": {
      "default": "./custom-elements.json"
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit"
  },
  "dependencies": {
    "@tyui/core": "workspace:*"
  },
  "devDependencies": {
    "@tyui/tools-executors": "workspace:*"
  }
}
