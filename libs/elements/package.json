{
  "name": "@toyu-ui/elements",
  "version": "0.1.0",
  "keywords": [
    "tanstack-intent"
  ],
  "homepage": "https://github.com/jurokapsiar/tyui#readme",
  "bugs": {
    "url": "https://github.com/jurokapsiar/tyui/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jurokapsiar/tyui.git",
    "directory": "libs/elements"
  },
  "files": [
    "dist",
    "skills",
    "!skills/_artifacts",
    "custom-elements.json"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/button.d.ts",
      "default": "./dist/button.js"
    },
    "./center": {
      "types": "./dist/center.d.ts",
      "default": "./dist/center.js"
    },
    "./checkbox": {
      "types": "./dist/checkbox.d.ts",
      "default": "./dist/checkbox.js"
    },
    "./cluster": {
      "types": "./dist/cluster.d.ts",
      "default": "./dist/cluster.js"
    },
    "./container": {
      "types": "./dist/container.d.ts",
      "default": "./dist/container.js"
    },
    "./flex": {
      "types": "./dist/flex.d.ts",
      "default": "./dist/flex.js"
    },
    "./frame": {
      "types": "./dist/frame.d.ts",
      "default": "./dist/frame.js"
    },
    "./grid": {
      "types": "./dist/grid.d.ts",
      "default": "./dist/grid.js"
    },
    "./input": {
      "types": "./dist/input.d.ts",
      "default": "./dist/input.js"
    },
    "./radio": {
      "types": "./dist/radio.d.ts",
      "default": "./dist/radio.js"
    },
    "./radio-group": {
      "types": "./dist/radio-group.d.ts",
      "default": "./dist/radio-group.js"
    },
    "./sidebar": {
      "types": "./dist/sidebar.d.ts",
      "default": "./dist/sidebar.js"
    },
    "./custom-elements.json": {
      "default": "./custom-elements.json"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit"
  },
  "dependencies": {
    "@toyu-ui/core": "^0.1.0"
  }
}
