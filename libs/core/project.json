{
  "name": "core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/core/src",
  "targets": {
    "build": {
      "executor": "@toyu-ui/tools-executors:build"
    },
    "test": {
      "executor": "@toyu-ui/tools-executors:test",
      "options": {
        "browser": false,
        "watch": false,
        "coverage": false
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "libs/core",
        "command": "tsc -p tsconfig.lib.json --noEmit"
      }
    }
  },
  "tags": ["scope:libs", "type:library"]
}
